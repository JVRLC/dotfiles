# =============================================================================
# PATH
# =============================================================================
eval "$(/opt/homebrew/bin/brew shellenv)"

export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/opt/postgresql@15/bin:$PATH"
export PATH="/Library/TeX/texbin:$PATH"
export PATH="$HOME/.poetry/bin:$PATH"
export PATH="/usr/local/go/bin:$PATH"
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

# =============================================================================
# PLUGINS (zinit)
# =============================================================================
source $(brew --prefix)/opt/zinit/zinit.zsh

# Oh-my-zsh lib (git aliases, completion, etc.)
zinit snippet OMZL::git.zsh
zinit snippet OMZP::git

# Thème Dracula
zinit ice as"theme" depth"1"
zinit light dracula/zsh

# Plugins (chargés après le prompt = démarrage instantané)
zinit ice wait lucid
zinit light zsh-users/zsh-autosuggestions

zinit ice wait lucid
zinit light zsh-users/zsh-syntax-highlighting

zinit ice wait lucid
zinit light Aloxaf/fzf-tab

# =============================================================================
# KEYBINDINGS
# =============================================================================
bindkey -s '^v' 'nvim $(fzf)^M'
bindkey '^f' fzf-cd-widget

# Ctrl+!! → toggle sudo
sudo-command-line() {
    [[ -z $BUFFER ]] && zle up-history
    if [[ $BUFFER == sudo\ * ]]; then
        LBUFFER="${LBUFFER#sudo }"
    elif [[ $BUFFER == $EDITOR\ * ]]; then
        LBUFFER="${LBUFFER#$EDITOR }"
        LBUFFER="sudoedit $LBUFFER"
    elif [[ $BUFFER == sudoedit\ * ]]; then
        LBUFFER="${LBUFFER#sudoedit }"
        LBUFFER="$EDITOR $LBUFFER"
    else
        LBUFFER="sudo $LBUFFER"
    fi
}
zle -N sudo-command-line
bindkey "!!" sudo-command-line
bindkey -M vicmd '!!' sudo-command-line

# Désactiver Ctrl+S (compatibilité vim)
[[ -t 0 && $- = *i* ]] && stty -ixon

# =============================================================================
# ALIASES
# =============================================================================

# Éditeur
alias vim="nvim"
alias vi="nvim"
alias v="nvim"

# Terminal
alias tm="tmux"
alias lg="lazygit"
alias cdl='cd "$@" && ls'
alias dotfiles-sync="cp ~/Desktop/dotfiles/wezterm/wezterm.lua ~/.wezterm.lua && cp ~/Desktop/dotfiles/wezterm/wezterm.lua ~/.config/wezterm/wezterm.lua"

# Utilitaires
alias meteo="curl http://wttr.in/Sophia-Antipolis"
alias edt="open 'https://edtweb.univ-cotedazur.fr/direct/index.jsp?code=22311461&login=Individuel&password=&showTree=false&displayConfName=VisuV&projectId=5'"
alias rg="rgrep -n"
alias gv="grep -v"
alias grep="grep --color=auto"
export GREP_COLORS="ms=01;32:mc=01;32:sl=:cx=:fn=32:ln=32:bn=32:se=32"

# Git
alias gp="git push"
alias gcs="git checkout staging"

# Docker
alias dps="docker ps"
alias di="docker inspect"
alias dvi="docker volume inspect"
alias dni="docker network inspect"
alias dc="docker-compose"
alias dcu="docker-compose up"
alias dcud="docker-compose up -d"
alias dcub="docker-compose up --build"
alias dcd="docker-compose down"
alias dcs="docker-compose stop"
alias dcl="docker-compose logs -f"
alias dcp="docker-compose pull"
alias dcr="docker-compose restart"

# claude
alias cc="claude"

# =============================================================================
# FZF
# =============================================================================
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

export FZF_CTRL_R_OPTS="
  --preview 'echo {}'
  --preview-window up:3:hidden:wrap
  --bind 'ctrl-/:toggle-preview'
  --color header:italic
  --header 'Ctrl+/ pour afficher la prévisualisation'"

# =============================================================================
# NVM (Node)
# =============================================================================
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"

# =============================================================================
# PYENV (Python)
# =============================================================================
export PATH="$(brew --prefix pyenv)/bin:$PATH"
export PATH="$HOME/Library/Python/3.9/bin:$PATH"
export VIRTUALENVWRAPPER_PYTHON=$(which python3)
eval "$(pyenv init --path)"
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"

# =============================================================================
# SSH AGENT
# =============================================================================
eval "$(ssh-agent)" &> /dev/null
if ! ssh-add -l | grep -q github; then
    ssh-add "$HOME/.ssh/github" &> /dev/null
fi
